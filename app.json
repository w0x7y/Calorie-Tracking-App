{
  "expo": {
    "name": "calorie-tracker",
    "slug": "calorie-tracking-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Calorie Tracker to access your camera to scan product barcodes."
        }
      ],
      [
        "react-native-health",
        {
          "healthSharePermission": "Allow Calorie Tracker to read your daily step count from Apple Health.",
          "healthUpdatePermission": "Allow Calorie Tracker to write health data when you enable future Apple Health features."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f2bbfe42-7b2c-4c37-a8de-08055f81081d"
      }
    },
    "owner": "w0x7y"
  }
}
