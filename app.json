{
  "expo": {
    "name": "calorie-tracker",
    "slug": "calorie-tracking-app",
    "scheme": "calorie-tracking-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B3E"
    },
    "ios": {
      "bundleIdentifier": "com.w0x7y.calorietrackingapp",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.w0x7y.calorietrackingapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1B3E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Calorie Tracker to access your camera to scan product barcodes."
        }
      ],
      [
        "react-native-health",
        {
          "healthSharePermission": "Allow Calorie Tracker to read your daily step count from Apple Health.",
          "healthUpdatePermission": "Allow Calorie Tracker to write health data when you enable future Apple Health features."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f2bbfe42-7b2c-4c37-a8de-08055f81081d"
      }
    },
    "owner": "w0x7y"
  }
}
